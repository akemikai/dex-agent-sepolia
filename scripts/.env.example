# Stabilizer DEX Config - Complete
# Copy this to .env and fill in your values

# === REQUIRED ===
# Your private key (wallet yang dapat USDC di Sepolia)
PRIVATE_KEY=0xc5a527d491739c20b439a67aed29fb26eca2edd4b784fe45f3eecb990b6a4e6c

# === OPTIONAL - Wallet 2, 3, etc ===
# PRIVATE_KEY_2=0x...
# PRIVATE_KEY_3=0x...

# === NETWORK ===
RPC_URL=https://sepolia.infura.io/v3/84842078b09946638c03157f83405213
CHAIN_ID=11155111

# === SWAP SETTINGS ===
SELL_TOKEN=USDC
BUY_TOKEN=USDT
AMOUNT=60

# === LOOP SETTINGS ===
# Max transactions per run
MAX_TX=10

# Delay between swaps (seconds)
DELAY=30

# === AUTO RETRY ===
# Number of retries if swap fails (default: 3)
RETRY=3

# === SCHEDULE ===
# Run automatically: "30m" = every 30 min, "1h" = every hour, "2h" = every 2 hours
# Leave empty or comment to run once manually
SCHEDULE=

# === MULTIPLE PAIRS (optional) ===
# Rotate between pairs: "USDC-USDT,USDT-USDC,USDC-USDZ"
# PAIRS=USDC-USDT,USDT-USDC
# Stabilizer DEX Config - Multi Wallet with Schedule
RPC_URL=https://sepolia.infura.io/v3/84842078b09946638c03157f83405213

# Wallet 1 (required)
PRIVATE_KEY=0x...

# Wallet 2 (optional)
PRIVATE_KEY_2=0x...

# Loop Settings
MAX_TX=10
DELAY=30

# Retry if failed (default: 3)
RETRY=3

# Schedule (use "2h" for 2 hours, "30m" for 30 minutes)
# Leave empty to run once
SCHEDULE=2h